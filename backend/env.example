# Server Configuration
PORT=3001
NODE_ENV=development

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# PostgreSQL Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=vortex_athletics
DB_USER=postgres
DB_PASSWORD=your_postgres_password
# Alternatively set a single connection URL in production
# DATABASE_URL=postgres://user:password@host:5432/database

# JWT Secret (required in production)
JWT_SECRET=your-super-secret-jwt-key-here

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS + API limits
API_RATE_LIMIT_MAX=1000

# Email / SMTP
# Transactional email is sent via Nodemailer (backend/email/sendEmail.js).
# Recommended: a Google Workspace mailbox using an App Password.
#   1. Enable 2-Step Verification on the sending Google account.
#   2. Create an App Password at https://myaccount.google.com/apppasswords
#      (16 characters, no spaces).
#   3. Set the values below in Render (backend service env vars) and, for local
#      development, in backend/.env.local. Redeploy after changing them.
# When SMTP_USER / SMTP_PASS are unset, no emails are sent (calls log and no-op).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=team@vortexathletics.com
SMTP_PASS=your-16-char-app-password
# Visible From. Once notify.vortexathletics.com is verified at the ESP, prefer:
#   "Vortex Athletics <accounts@notify.vortexathletics.com>"
SMTP_FROM="Vortex Athletics <team@vortexathletics.com>"
# Monitored Reply-To (front desk). Parent replies should reach a real, watched mailbox.
EMAIL_REPLY_TO=frontdesk@vortexathletics.com

# --- Email deliverability (see docs/email-deliverability-audit.md) ---
EMAIL_BRAND_NAME=Vortex Athletics
VORTEX_ROOT_DOMAIN=vortexathletics.com
EMAIL_TRANSACTIONAL_SUBDOMAIN=notify
EMAIL_MARKETING_SUBDOMAIN=news
# Diagnostic only: DKIM selector(s) for scripts/check-email-domain-authentication.mjs
DKIM_SELECTORS=google
# Sending policy (anti-burst / anti-duplicate)
EMAIL_RESEND_COOLDOWN_SEC=120
EMAIL_DAILY_PER_ADDRESS_MAX=5
EMAIL_MAX_REMINDERS=2
EMAIL_REMINDER_INTERVAL_DAYS=7
EMAIL_PER_TENANT_HOURLY_MAX=500
# Incident kill switches: EMAIL_KILL_SWITCH stops ALL mail; per-category e.g.
# EMAIL_KILL_SWITCH_PARENT_ACCOUNT_INVITATION=true
EMAIL_KILL_SWITCH=false

# Public URL embedded in transactional email links (invites, verification, receipts).
# Email links always use https://www.vortexathletics.com unless this is set to a
# non-localhost URL (e.g. staging). Leave unset for production links even in local dev.
# PUBLIC_APP_URL=https://www.vortexathletics.com

# External waiver form link (JackRabbit) used by scheduling waiver emails.
# WAIVER_URL=https://app.jackrabbitclass.com/regv2.asp?id=557920

# Coaching exercise media uploads (optional, Cloudinary signed direct upload)
# When unset, the exercise editor falls back to pasting a hosted media URL.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# LLM (Vercel AI SDK + OpenAI — optional; rule-based fallbacks when unset)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Analytics integrations (optional)
GA4_PROPERTY_ID=123456789
GSC_SITE_URL=https://www.vortexathletics.com
GOOGLE_APPLICATION_CREDENTIALS_JSON={"type":"service_account"}
ERROR_ALERT_WEBHOOK_URL=

# Migration endpoint safety
ENABLE_MIGRATION_ENDPOINT=false
MIGRATION_SECRET_KEY=replace-with-long-random-secret

# Billing / payment mode (launch with external reconciliation)
PAYMENTS_PROVIDER=external
STRIPE_ENABLED=true
# Stripe keys — use test keys (sk_test_... / pk_test_...) until go-live; never commit real secrets.
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
# Webhook signing secret:
#   Docker/local — run `stripe listen --forward-to localhost:3001/api/stripe/webhook` and use its whsec_... secret.
#   Production — Stripe Dashboard → Webhooks → endpoint for your deployed API /api/stripe/webhook
STRIPE_WEBHOOK_SECRET=
EXTERNAL_PAYMENT_PROCESSOR_NAME=External Payment Processor
