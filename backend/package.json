{
  "name": "vortex-backend",
  "version": "1.0.0",
  "description": "Vortex Athletics Backend API",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "test": "node --test",
    "check:email-auth": "node scripts/check-email-domain-authentication.mjs",
    "seed-events": "node seed-events.js",
    "seed:dev-members": "node members/runSeedDevMembers.js",
    "migrate": "node run-migration.js",
    "migrate:all": "node run-migration.js --all",
    "repair:needs-engine-schema": "node scripts/repair-needs-engine-schema.mjs",
    "repair:boot-constraints": "node -e \"import pg from 'pg'; import dotenv from 'dotenv'; import { ensureCoachingBootConstraints } from './platform/ensureCoachingBootConstraints.js'; dotenv.config({path:'.env.local'}); const cs=process.env.EXTERNAL_DB_URL||process.env.DB_URL; const p=new pg.Pool({connectionString:cs,ssl:{rejectUnauthorized:false}}); await ensureCoachingBootConstraints(p); await p.end(); console.log('done');\"",
    "repair:failed-seeds": "node scripts/repair-failed-seed-migrations.mjs",
    "audit:boot-migrations": "node scripts/audit-boot-migration-failures.mjs",
    "billing:recurring": "node scheduling/runRecurringCharges.js",
    "stripe:sync-catalog": "node billing/runStripeCatalogSync.js",
    "bootstrap:staging-rehearsal": "node scripts/bootstrap-staging-rehearsal-accounts.mjs",
    "verify:module0": "node verify-module0.js",
    "list-tables": "DB_HOST=localhost DB_PORT=5432 DB_NAME=vortex_athletics DB_USER=postgres DB_PASSWORD=vortex2024 node list-all-tables.js",
    "postinstall": "echo 'Backend dependencies installed'"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.73",
    "ai": "^6.0.208",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.10.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "googleapis": "^144.0.0",
    "helmet": "^7.1.0",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^6.10.1",
    "pdfkit": "^0.19.1",
    "pg": "^8.11.3",
    "stripe": "^22.3.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  }
}
